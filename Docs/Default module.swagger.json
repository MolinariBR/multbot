    "/deposits": {
      "get": {
        "summary": "Deposits",
        "deprecated": false,
        "description": "This API returns a list of deposits in a compact form. It may be used from time to time as a fallback in case the webhook fails.\n\nIt currently returns up to 200 rows per query.\n\nParameters:\n- start included, end excluded - \\[start, end)\n- status - Refer to [Deposit Status String documentation](https://docs.eulen.app/deposit-status-string-1443187m0)",
        "tags": [
          "API Endpoints"
        ],
        "parameters": [
          {
            "name": "start",
            "in": "query",
            "description": "Start date (included) in YYYY-MM-DD format or RFC3339.",
            "required": true,
            "type": "string",
            "x-example": "2006-01-01 or 2006-01-01T00:00:00-03:00"
          },
          {
            "name": "end",
            "in": "query",
            "description": "End date (excluded) in YYYY-MM-DD format or RFC3339.",
            "required": true,
            "type": "string",
            "x-example": "2006-02-01 or 2006-02-01T00:00:00-03:00"
          },
          {
            "name": "status",
            "in": "query",
            "description": "A status to filter by.",
            "required": false,
            "enum": [
              "pending",
              "depix_sent",
              "under_review",
              "canceled",
              "error",
              "refunded",
              "expired",
              "pending_pix2fa",
              "delayed"
            ],
            "type": "string",
            "x-example": ""
          },
          {
            "name": "X-Nonce",
            "in": "header",
            "description": "A random uuid string to identify an CLIENT INTENTION as unique. In case of retrying the same request, always use the same nonce. For new operations, use a new one. By default, if this param is empty, a new nonce would be generated.",
            "required": false,
            "format": "uuid",
            "type": "string",
            "x-example": ""
          },
          {
            "name": "X-Async",
