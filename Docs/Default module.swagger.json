            "description": "Can be true, false or auto. If not auto forces API async or sync behavior.",
            "default": "auto",
            "type": "string",
            "x-example": "auto"
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "headers": {},
            "examples": {
              "application/json": [
                {
                  "qrId": "0198443f48c273d3afc72eb454025d19",
                  "status": "depix_sent",
                  "bankTxId": "71"
                },
                {
                  "qrId": "0198443f48c273d3afc72eb454025d19",
