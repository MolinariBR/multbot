    "/deposit": {
      "post": {
        "summary": "Deposit (PIX ➔ DePix)",
        "deprecated": false,
        "description": "The system generates a dynamic QR code designed for deposits in Reais (BRL) through the PIX banking system. The QR code is provided in two formats: text format, which allows for easy copy-and-paste into banking applications, and PNG format, displaying a scannable QR code image for convenience.\n\nWhen a deposit is successfully made using the generated QR code, our system automatically processes the transaction, converting the deposited amount into DePix. The converted DePix can then be sent to a default partner address or to a custom address specified as a parameter during the QR code generation.",
        "tags": [
          "API Endpoints"
        ],
        "parameters": [
          {
            "name": "X-Nonce",
            "in": "header",
            "description": "A random uuid string to identify an CLIENT INTENTION as unique. In case of retrying the same request, always use the same nonce. For new operations, use a new one. By default, if this param is empty, a new nonce would be generated.",
            "required": false,
            "format": "uuid",
            "type": "string",
            "x-example": ""
          },
          {
            "name": "X-Async",
            "in": "header",
            "description": "Can be true, false or auto. If not auto forces API async or sync behavior.",
            "default": "auto",
            "type": "string",
            "x-example": "auto"
          },
          {
            "name": "body",
            "in": "body",
            "schema": {
              "type": "object",
              "properties": {
                "amountInCents": {
                  "type": "integer",
                  "title": "Amount in cents",
                  "minimum": 1,
                  "maximum": 10000000,
                  "description": "Integer value in cents of reais. For R$ 1,00 for example: the number passed must be 100."
                },
                "depixAddress": {
                  "type": "string",
                  "description": "Optional DePix Address"
                },
                "depixSplitAddress": {
                  "type": "string",
                  "description": "Optional DePix Split Address"
                },
                "splitFee": {
                  "type": "string",
                  "description": "Optional Split Fee (the percentage of amountInCents that will be splitted and sent to depixSplitAddress)"
                },
                "euid": {
                  "type": "string",
                  "description": "End user EUID"
                },
                "endUserFullName": {
                  "type": "string",
                  "description": "End user full name"
                },
                "endUserTaxNumber": {
                  "type": "string",
                  "description": "End user tax number"
                },
                "whitelist": {
                  "type": "boolean",
                  "description": "Optional whitelist flag",
                  "default": false
                },
                "lightning": {
                  "type": "boolean",
                  "description": "Optional lightning flag",
                  "default": false
                },
                "pix2fa": {
                  "type": "boolean",
                  "description": "Optional pix2fa flag (force pix2fa flow even when not a new user)"
                },
                "pix2faMessage": {
                  "type": "string",
                  "description": "Optional custom Pix2FA message (must include a \"%s\" placeholder for injection of Pix2FA code)"
                },
                "delayDepixInHours": {
                  "type": "integer",
                  "description": "Optional number of hours to delay the DePix payment (min 1, max 720). If omitted, the payment is processed immediately."
                }
              },
              "required": [
                "amountInCents"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "headers": {
              "X-Request-ID": {
                "example": "8ddc3426-1425-4d80-b588-a05371119da0",
                "required": true,
                "description": "UUID for each request",
                "type": "string"
              },
              "X-Nonce": {
                "example": "3e5f32c10786",
                "required": true,
                "description": "The same nonce sent by user",
                "type": "string"
              }
            },
            "schema": {
              "$ref": "#/definitions/DepositResponse"
            }
          },
          "202": {
