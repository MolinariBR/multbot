{
  "name": "@multbot/backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npx prisma generate && node scripts/ensure-prisma-symlink.mjs && tsc",
    "start": "node dist/index.js",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "lint": "pnpm exec eslint --config ../../eslint.config.mjs \"src/**/*.{ts,tsx,js,mjs,cjs}\" \"prisma/**/*.{ts,js,mjs,cjs}\" \"scripts/**/*.{ts,js,mjs,cjs}\"",
    "lint:strict": "pnpm exec eslint --config ../../eslint.strict.config.mjs \"src/**/*.{ts,tsx,js,mjs,cjs}\" \"prisma/**/*.{ts,js,mjs,cjs}\" \"scripts/**/*.{ts,js,mjs,cjs}\"",
    "format": "pnpm exec prettier --write \"src/**/*.{ts,tsx,js,mjs,cjs,json}\" \"prisma/**/*.{ts,js,mjs,cjs,json}\" \"scripts/**/*.{ts,js,mjs,cjs}\"",
    "format:check": "pnpm exec prettier --check \"src/**/*.{ts,tsx,js,mjs,cjs,json}\" \"prisma/**/*.{ts,js,mjs,cjs,json}\" \"scripts/**/*.{ts,js,mjs,cjs}\""
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/swagger": "^9.4.0",
    "@prisma/client": "^6.4.0",
    "@scalar/fastify-api-reference": "^1.28.0",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.5.0",
    "fastify": "^5.2.0",
    "jsonwebtoken": "^9.0.2",
    "node-telegram-bot-api": "^0.66.0",
    "nodemailer": "^6.10.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.4.0",
    "qrcode": "^1.5.4",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.0",
    "@types/node-telegram-bot-api": "^0.64.8",
    "@types/nodemailer": "^6.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
